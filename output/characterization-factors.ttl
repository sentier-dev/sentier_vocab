@prefix ns1: <https://vocab.sentier.dev/ontology/> .
@prefix ns2: <http://qudt.org/schema/qudt/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://vocab.sentier.dev/characterization-factors/> a skos:ConceptScheme .

<https://vocab.sentier.dev/characterization-factors/ipcc-2021_climate-change_ENVO_carbon_dioxide> a ns1:CharacterizationFactor ;
    ns2:hasUnit <http://qudt.org/vocab/unit/KiloGM> ;
    skos:inScheme <https://vocab.sentier.dev/characterization-factors/> ;
    skos:prefLabel "IPCC 2021 GWP100 — carbon dioxide"@en ;
    ns1:factorValue 1e+00 ;
    ns1:flow <https://vocab.sentier.dev/flows/ENVO_carbon_dioxide> ;
    ns1:impactCategory <https://vocab.sentier.dev/impact-categories/climate-change> ;
    ns1:method <https://vocab.sentier.dev/lcia-methods/ipcc-2021> .

